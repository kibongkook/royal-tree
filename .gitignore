# Chrome 자동화 (프로파일은 ~/Library에 두지만, 프로젝트 루트에 부산물 떨어지면 제외)
_cookie_backups/
chrome_user_data/

# 대용량 클론·다운로드 (재현 가능 — scripts/fetchers/ 로 재취득)
data/raw/huggingface/
data/raw/github/
# 단, 카탈로그 메타데이터는 보존
!data/raw/huggingface/catalog.jsonl
!data/raw/github/catalog.jsonl

# Wikipedia 임시 / 중간 산출물
data/raw/wikipedia/_tmp/
data/raw/wikipedia/*.run*
data/raw/wikipedia/_crawl*.log
data/raw/wikidata/_harvest.log
data/raw/wikipedia/_category_stats*

# 마스터 통합 부산물 (재생성 가능)
data/master/*.tmp
data/by_country/*.tmp
data/by_category/*.tmp
/tmp_*

# Phase-5 backups (recreated by scripts on each run)
data/master/*.pre_*.jsonl
.claude/
