{"id":"royals:islamic-atlas:62","names":{"en":"Sultans of Kilwa","tr":"Kilva Sultanları","ar":"Salāṭīn Kilwa"},"country":["ET","ML","NE","NG","SD","SO"],"category":"royal","period":{"founded":null,"extinct":null},"status":"extinct","head_current":null,"sources":["github:alicetinkaya76/islamic-civilization-atlas:all_dynasties_enriched.csv"],"raw":{"atlas_dynasty_id":"62","atlas_name_en_original":"The Sultans of Kilwa","parent_tribe":"1. Şîrâzî hanedanı; 2. Mehdâlî Seyyidler","ethnic_origin":"Arap/Şîrâzî (iddia) / Svahili","capital":"Kilva (Quiloa)","region_primary":"Kilva adası (Tanzanya kıyısı)","regions_all":"Kilva (Kilwa Kisawani); Doğu Afrika kıyı ticareti","geographic_zone":"Doğu/Batı Afrika","predecessor":null,"successor":"Portekiz vasalları; ardından Umânlı kontrol; Bû Saîdîler (Zengibar)","government_type":"Sultanlık","religious_orientation":null,"narrative_en":"The Kilwa Sultans were a Swahili dynasty controlling gold, ivory, and slave trade as the center of international maritime commerce on the East African coast. While the Shirazi origin claim is debated, Kilwa's minted coins evidence East Africa's earliest monetary system.","importance_level":"Normal","capital_lat":"-8.96","capital_lon":"39.52","century_start":null,"century_end":null}}
